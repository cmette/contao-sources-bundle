{% extends '@Contao/content_element/_base.html.twig' %}
{% use '@Contao/component/_figure.html.twig' %}
{% use '@Contao/component/_rich_text.html.twig' %}

{% use '@Contao/component/_authors.html.twig' %}
{% use '@Contao/component/_titles.html.twig' %}
{% use '@Contao/component/_series.html.twig' %}
{% use '@Contao/component/_catalogs.html.twig' %}
{% use '@Contao/component/_digitalcopies.html.twig' %}

{% set content_layout_attributes = attrs()
    .addClass('media media--' ~ layout, layout and image)
    .mergeWith(content_layout_attributes|default)
%}

{# By default we add the layout attributes to the wrapper element. If you want to
 disable this behavior, set "default_content_layout" to false. #}
{% set attributes = attrs(attributes|default)
    .set('id', "sources_entity-" ~ source.id)
    .addClass(source.type)
    .mergeWith(content_layout_attributes, default_content_layout is not defined or default_content_layout)
%}

{# Media #}
{% block text_media %}
    {% if image %}
        {% with {figure: image} %}{{ block('figure_component') }}{% endwith %}
    {% endif %}
{% endblock %}

{% block content %}
    {% if layout != 'below' %}
        {{ block('text_media') }}
    {% endif %}

    {% block text %}
        {% with { 'authors': source.getAuthorsAsArray(), 'settings': settings } %}
            {{- block('authors_component') -}}
        {% endwith %}
        {{- block('titles_component') -}}
        {%- with { 'publisher': source.getPublisher(), 'serie': source.getSerie() } -%}
            {{- block('series_component') -}}
        {% endwith %}
        {%- with { 'catalogs': source.getCatalogs() } -%}
            {{- block('catalogs_component') -}}
        {% endwith %}
        {%- with { 'digitalcopies': source.getDigitalcopies() } -%}
            {{- block('digitalcopies_component') -}}
        {% endwith %}.
    {% endblock %}

    {% if layout == 'below' %}
        {{ block('text_media') }}
    {% endif %}
{% endblock %}