{% trans_default_domain "tl_sources_entity" %}
{# rendert alle AutorInnen als Liste #}

{%- block authors_component -%}
    {%- set authors_attributes = attrs().addClass(settings.mode).addClass('authors') -%}
    <span{{- authors_attributes -}}>
    {%- for id,author in authors|slice(0,2) -%}
        <span class="{{- (author.published and author.enabled) ?'published':'unpublished' -}}">
            {{- author.family_name -}}
            {{- author.first_name ? ", #{author.first_name}" -}}
            {{- (author.role)?' '~('tl_sources_entity.authors_fields.role_options.' ~ author.role)|trans([], 'contao_tl_sources_entity') -}}
            {{- ((id|last < authors|length-1)?' & ' : (settings.mode == 'apa' ? ':' : ' ')) -}}
        </span>
    {%- endfor %}{{ (authors|length>2)?' et al.' -}}
    </span>
{%- endblock -%}