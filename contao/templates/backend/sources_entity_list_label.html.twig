{% use '@Contao/component/_authors.html.twig' %}
{% use '@Contao/component/_year.html.twig' %}
{% use '@Contao/component/_titles.html.twig' %}
{% use '@Contao/component/_series.html.twig' %}
{% use '@Contao/component/_publisher.html.twig' %}
{% use '@Contao/component/_metadata.html.twig' %}
{% use '@Contao/component/_occurrences.html.twig' %}

<div class="source-entity">
    {%- if source._imageHtml|default -%}
    <div class="initiale"><img src='bundles/contaosources/img/{{ source.type }}.svg' alt="{{ source.type }}"></div>
    {%- endif -%}
    <div class="data">
        <div>
            {%- if source -%}
                {{- block('authors_component') -}}
                {{- block('year_component') -}}
                {{- block('titles_component') -}}
                {{- block('series_component') -}}
                {{- block('publisher_component') -}}
                {{- block('metadata_component') -}}
                {{- block('occurrences_component') -}}
            {%- else -%}
                <div>{{- 'tl_sources_entity.source_not_found'|trans([], 'contao_tl_sources_entity') -}}</div>
            {%- endif -%}
        </div>
        {%- if source._imageHtml|default -%}
        <div>{{ source._imageHtml|raw }}</div>
        {%- endif -%}
    </div>
</div>